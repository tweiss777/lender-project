FROM node:20-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm install 

COPY . .
RUN npm run build

# ---- Production image ----
FROM nginx:alpine

# Copy built assets
COPY --from=builder /app/dist /usr/share/nginx/html

# Nginx config: serve the SPA and proxy /api to the server
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
